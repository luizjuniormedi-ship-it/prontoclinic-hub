# =============================================================================
# ProntoMedic — Variáveis de Ambiente
# =============================================================================
#
# Copie este arquivo para .env e preencha com os valores reais:
#   cp .env.example .env
#
# IMPORTANTE: o arquivo .env NUNCA deve ser commitado.
#
# Como obter as credenciais Supabase:
# 1. Acesse https://supabase.com/dashboard
# 2. Crie um projeto (ou use um existente)
# 3. Settings > API > Project URL e anon public key
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
VITE_APP_NAME=ProntoMedic
VITE_APP_ENV=development
# VITE_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Notificações por E-mail (Resend ou SendGrid)
# -----------------------------------------------------------------------------
# Resend (recomendado): https://resend.com/api-keys
VITE_RESEND_API_KEY=re_xxxxxxxxxxxx
VITE_EMAIL_FROM=nao-responda@seudominio.com.br
VITE_EMAIL_REPLY_TO=suporte@seudominio.com.br

# Templates customizados (opcional)
# VITE_TEMPLATES_PATH=/caminho/templates

# -----------------------------------------------------------------------------
# Notificações por WhatsApp (Z-API)
# -----------------------------------------------------------------------------
# VITE_ZAPI_INSTANCE_ID=xxxxxxxxxxxx
# VITE_ZAPI_TOKEN=xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Notificações por SMS (Twilio)
# -----------------------------------------------------------------------------
# VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# VITE_TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
# VITE_TWILIO_FROM_NUMBER=+5511999999999

# -----------------------------------------------------------------------------
# Telemedicina (Daily.co)
# -----------------------------------------------------------------------------
# Documentação: https://docs.daily.co/reference/rest-api
# Painel: https://dashboard.daily.co/
# VITE_DAILY_API_KEY=xxxxxxxxxxxx
# VITE_DAILY_DOMAIN=seu-dominio.daily.co
# VITE_DAILY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# A chave de API também é configurada como DAILY_API_KEY no Supabase (server-side)
# para a Edge Function daily-webhook. A VITE_DAILY_API_KEY é só para DEV local.

# -----------------------------------------------------------------------------
# Storage (S3 ou Supabase Storage)
# -----------------------------------------------------------------------------
# VITE_S3_BUCKET=prontomedic-exames
# VITE_S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
VITE_ENABLE_TELEMEDICINE=false
VITE_ENABLE_WHATSAPP=false

# -----------------------------------------------------------------------------
# PACS / DICOM (Orthanc, Conquest, AWS HealthImaging)
# -----------------------------------------------------------------------------
# Orthanc: PACS open source (https://www.orthanc-server.com)
# Recomendado instalar via Docker: docker run -p 8042:8042 -p 4242:4242 orthancteam/orthanc
# IMPORTANTE: Troque as credenciais padrão antes de subir para produção!
# O sistema VALIDARÁ que você não está usando orthanc/orthanc.
VITE_ORTHANC_URL=http://localhost:8042
VITE_ORTHANC_USER=CHANGE_ME_PACS_USER
VITE_ORTHANC_PASS=CHANGE_ME_STRONG_PASSWORD_MIN_8_CHARS

# Supabase Storage bucket para DICOM (.dcm) - criar em Storage > New bucket
VITE_DICOM_BUCKET=dicom

# Alternativas PACS:
# Conquest:        VITE_ORTHANC_URL=http://localhost:8080
# AWS HealthImaging: VITE_ORTHANC_URL=https://runtime-medical-imaging.us-east-1.amazonaws.com

# -----------------------------------------------------------------------------
# TISS / Faturamento Eletrônico (ANS)
# -----------------------------------------------------------------------------
# Versao do padrao TISS (3.05.00 vigente; verificar ANS periodicamente)
VITE_TISS_VERSION=3.05.00

# Caminho do certificado A1 (.pfx) para comunicacao com a ANS
# Em homologacao, nao obrigatorio
VITE_TISS_CERT_PATH=/etc/pc_hub/cert_a1.pfx
VITE_TISS_CERT_PASSWORD=

# Ambiente TISS (HOMOLOGACAO ou PRODUCAO)
VITE_TISS_AMBIENTE=HOMOLOGACAO

# Endpoints especificos por operadora (opcional - configurar via UI tambem)
# VITE_TISS_ENDPOINT_AMIL=https://amil.integracao-tiss.com.br/tiss/v3
# VITE_TISS_ENDPOINT_UNIMED=https://unimed.integracao-tiss.com.br/tiss/v3