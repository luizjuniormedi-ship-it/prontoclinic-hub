# =============================================================================
# ProntoMedic — .gitignore
# =============================================================================
# Migrado de .gitignore original (commit 949c59c) + melhorias de segurança
# =============================================================================

# -----------------------------------------------------------------------------
# Dependências
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Ambiente (CRÍTICO — NUNCA COMMITAR)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.staging
.env.staging.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Build
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
*.local
.vite/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Editor
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testes / Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/
.playwright/

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# -----------------------------------------------------------------------------
# Sistema
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Supabase local
# -----------------------------------------------------------------------------
supabase/.branches
supabase/.temp
supabase/.env

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.history/
.tmp/
.tmp-*